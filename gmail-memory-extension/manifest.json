{
  "manifest_version": 3,
  "name": "Claude Memory Saver",
  "version": "1.5.0",
  "description": "Save Gmail, Google Docs, Claude.ai, TikTok comments, and WhatsApp messages to Claude Memory.",
  "permissions": [
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "http://localhost:8765/*",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content-docs.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*", "https://tiktok.com/*"],
      "js": ["content-tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content-whatsapp.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
